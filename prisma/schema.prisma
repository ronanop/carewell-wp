// Experience Studio (ADR-011) + Lead Engine (ADR-013) — PostgreSQL schema.
// Studio: presentation configuration only. Never store WordPress page/post HTML.
// Leads: patient enquiry / CRM / append-only timeline (see Lead models below).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  EDITOR
  MARKETING
  DEVELOPER
}

enum PresentationStatus {
  DRAFT
  PUBLISHED
}

enum VersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GalleryCategory {
  BEFORE_AFTER
  PROCEDURE
  HOSPITAL
}

enum ReviewSource {
  GOOGLE
  VIDEO
  MANUAL
}

enum CtaScope {
  GLOBAL
  TEMPLATE
  PAGE
}

model Role {
  id        String   @id @default(cuid())
  name      RoleName @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  active       Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@index([roleId])
}

/// Tenant / site root for Experience Studio presentation data.
model Site {
  id          String          @id @default(cuid())
  key         String          @unique @default("default")
  name        String          @default("Care Well Medical Centre")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  pages       WordPressPage[]
  posts       WordPressPost[]
  templates   Template[]
  staticPages StaticPage[]
}

/// WordPress post metadata only — never article HTML (Blog Engine / Phase 6.0).
model WordPressPost {
  id                    String            @id @default(cuid())
  siteId                String
  site                  Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  databaseId            Int
  uri                   String
  slug                  String
  title                 String
  status                String
  excerpt               String?
  featuredImageUrl      String?
  seoTitle              String?
  authorName            String?
  authorSlug            String?
  /// Comma-separated category slugs for Studio filters.
  categorySlugs         String            @default("")
  categoryNames         String            @default("")
  lastWordPressModified DateTime
  lastSyncedAt          DateTime
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  presentation          BlogPresentation?

  @@unique([siteId, databaseId])
  @@unique([siteId, uri])
  @@index([siteId, slug])
  @@index([siteId, status])
  @@index([authorSlug])
  @@index([lastWordPressModified])
}

/// PresentationConfig JSON for one WordPress post (mirrors PagePresentation).
model BlogPresentation {
  id          String                   @id @default(cuid())
  postId      String                   @unique
  post        WordPressPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  status      PresentationStatus       @default(DRAFT)
  /// BlogPresentationConfig JSON — presentation only, never WP content.
  config      Json
  publishedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  versions    BlogPresentationVersion[]

  @@index([status])
}

model BlogPresentationVersion {
  id             String           @id @default(cuid())
  presentationId String
  presentation   BlogPresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  version        Int
  status         VersionStatus    @default(DRAFT)
  snapshot       Json
  note           String?
  createdById    String?
  createdAt      DateTime         @default(now())

  @@unique([presentationId, version])
  @@index([presentationId, createdAt])
  @@index([presentationId, status])
}

/// WordPress page metadata only — never article HTML.
model WordPressPage {
  id                    String            @id @default(cuid())
  siteId                String
  site                  Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  databaseId            Int
  uri                   String
  slug                  String
  title                 String
  status                String
  wpTemplate            String?
  featuredImageUrl      String?
  seoTitle              String?
  parentDatabaseId      Int?
  /// Last modified timestamp from WordPress.
  lastWordPressModified DateTime
  lastSyncedAt          DateTime
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  presentation          PagePresentation?

  @@unique([siteId, databaseId])
  @@unique([siteId, uri])
  @@index([siteId, slug])
  @@index([siteId, status])
  @@index([lastWordPressModified])
}

/// Named presentation template defaults (seeded; CRUD comes later).
model Template {
  id              String             @id @default(cuid())
  siteId          String
  site            Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug            String
  name            String
  description     String?
  previewImageUrl String?
  sortOrder       Int                @default(0)
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  presentations   PagePresentation[]

  @@unique([siteId, slug])
  @@index([siteId, sortOrder])
}

/// Presentation configuration for one WordPress page.
/// `config` is the PresentationConfig JSON contract (media IDs only — never URLs).
model PagePresentation {
  id          String               @id @default(cuid())
  pageId      String               @unique
  page        WordPressPage        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  templateId  String?
  template    Template?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status      PresentationStatus   @default(DRAFT)
  /// PresentationConfig JSON — single source of truth for Studio ↔ Frontend.
  config      Json
  publishedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  versions    PresentationVersion[]

  @@index([templateId])
  @@index([status])
}

model PresentationVersion {
  id             String           @id @default(cuid())
  presentationId String
  presentation   PagePresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  version        Int
  status         VersionStatus    @default(DRAFT)
  /// Full PresentationConfig snapshot — publishing never overwrites prior rows.
  snapshot       Json
  note           String?
  createdById    String?
  createdAt      DateTime         @default(now())

  @@unique([presentationId, version])
  @@index([presentationId, createdAt])
  @@index([presentationId, status])
}

/// Handcrafted / marketing page registered in StaticPageRegistry (Phase 4.7 / ADR-014).
/// Not linked to WordPress — presentation only.
model StaticPage {
  id           String                   @id @default(cuid())
  siteId       String
  site         Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  /// Catalog slug: home | about | contact | …
  slug         String
  path         String
  title        String
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  presentation StaticPagePresentation?

  @@unique([siteId, slug])
  @@unique([siteId, path])
  @@index([siteId])
}

/// PresentationConfig for one static page (same JSON contract as WordPress PagePresentation).
model StaticPagePresentation {
  id          String                      @id @default(cuid())
  pageId      String                      @unique
  page        StaticPage                  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  status      PresentationStatus          @default(DRAFT)
  config      Json
  publishedAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  versions    StaticPresentationVersion[]

  @@index([status])
}

model StaticPresentationVersion {
  id             String                 @id @default(cuid())
  presentationId String
  presentation   StaticPagePresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  version        Int
  status         VersionStatus          @default(DRAFT)
  snapshot       Json
  note           String?
  createdById    String?
  createdAt      DateTime               @default(now())

  @@unique([presentationId, version])
  @@index([presentationId, createdAt])
  @@index([presentationId, status])
}

/// Presentation profile for clinic doctors (placeholder module).
model DoctorProfile {
  id                   String   @id @default(cuid())
  wordpressSlug        String?  @unique
  displayName          String
  designation          String?
  credentials          String?
  experienceLabel      String?
  awards               String?
  imageUrl             String?
  socialLinkedIn       String?
  socialInstagram      String?
  availabilityNote     String?
  consultationCtaLabel String?
  consultationCtaHref  String?
  sortOrder            Int      @default(0)
  published            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Gallery {
  id        String          @id @default(cuid())
  name      String
  category  GalleryCategory
  sortOrder Int             @default(0)
  published Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     GalleryItem[]
}

model GalleryItem {
  id             String   @id @default(cuid())
  galleryId      String
  gallery        Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  title          String?
  imageUrl       String
  altText        String?
  beforeImageUrl String?
  afterImageUrl  String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([galleryId])
}

model Review {
  id         String       @id @default(cuid())
  source     ReviewSource
  authorName String
  rating     Int?
  body       String?
  videoUrl   String?
  featured   Boolean      @default(false)
  published  Boolean      @default(true)
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([source, featured])
}

model CTAConfiguration {
  id              String   @id @default(cuid())
  scope           CtaScope
  name            String
  templateSlug    String?
  wordpressPageId String?
  primaryLabel    String
  primaryHref     String
  secondaryLabel  String?
  secondaryHref   String?
  whatsappEnabled Boolean  @default(true)
  callEnabled     Boolean  @default(true)
  bookEnabled     Boolean  @default(true)
  stickyBottom    Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scope])
}

model ThemeConfiguration {
  id                     String            @id @default(cuid())
  key                    String            @unique @default("default")
  logoUrl                String?
  faviconUrl             String?
  primaryColor           String?
  accentColor            String?
  footerText             String?
  announcementBarText    String?
  announcementBarEnabled Boolean           @default(false)
  contactPhone           String?
  contactEmail           String?
  contactAddress         String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  socialLinks            ThemeSocialLink[]
}

model ThemeSocialLink {
  id        String             @id @default(cuid())
  themeId   String
  theme     ThemeConfiguration @relation(fields: [themeId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  sortOrder Int                @default(0)

  @@index([themeId])
}

/// Global Consultation Sidebar settings (Phase 4.6A) — page chrome, not content.
model ConsultationSidebarSettings {
  id                       String   @id @default(cuid())
  key                      String   @unique @default("default")
  enabled                  Boolean  @default(true)
  desktopWidthPx           Int      @default(340)
  stickyOffsetPx           Int      @default(120)
  minWidthPx               Int      @default(320)
  maxWidthPx               Int      @default(360)
  variant                  String   @default("premium")
  theme                    String   @default("medical-white")
  heading                  String   @default("Book Your Consultation")
  subtitle                 String   @default("Speak directly with our specialists. Quick response within 30 minutes.")
  ctaLabel                 String   @default("Book Consultation")
  badgeLabel               String   @default("FREE CONSULTATION")
  phoneNumber              String   @default("+91 9667-977-499")
  whatsappNumber           String   @default("919667977499")
  emergencyNumber          String   @default("+91 9667-977-499")
  successMessage           String   @default("Thank you — we will contact you shortly.")
  animation                String   @default("premium")
  showTrustBadges          Boolean  @default(true)
  googleRatingLabel        String   @default("★★★★★ Google Rating")
  patientsLabel            String   @default("1000+ Happy Patients")
  responseBadge            String   @default("Quick response within 30 minutes")
  doctorAvailabilityLabel  String   @default("Specialists available today")
  /// Partial Record<PageType, boolean>
  visibilityByPageType     Json     @default("{}")
  /// string[] of absolute URIs
  excludedUris             Json     @default("[]")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  summary    String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// =============================================================================
// Asset Management System (ADR-018) — Studio metadata only.
// WordPress Media Library remains the sole binary store. Never store file bytes.
// =============================================================================

/// Virtual folder (no filesystem) — membership keyed by WordPress media ID.
model AssetFolder {
  id        String              @id @default(cuid())
  slug      String              @unique
  name      String
  parentId  String?
  parent    AssetFolder?        @relation("AssetFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  AssetFolder[]       @relation("AssetFolderTree")
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  members   AssetFolderMember[]

  @@index([parentId])
  @@index([sortOrder])
}

model AssetFolderMember {
  id               String      @id @default(cuid())
  folderId         String
  folder           AssetFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  wordpressMediaId Int
  createdAt        DateTime    @default(now())

  @@unique([folderId, wordpressMediaId])
  @@index([wordpressMediaId])
}

model AssetFavorite {
  id               String   @id @default(cuid())
  userId           String
  wordpressMediaId Int
  createdAt        DateTime @default(now())

  @@unique([userId, wordpressMediaId])
  @@index([wordpressMediaId])
  @@index([userId])
}

/// Where an asset is referenced across Studio presentation configs.
model AssetUsage {
  id               String   @id @default(cuid())
  wordpressMediaId Int
  contextType      String
  contextId        String
  contextLabel     String
  fieldPath        String
  editorHref       String?
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([wordpressMediaId, contextType, contextId, fieldPath])
  @@index([wordpressMediaId])
  @@index([contextType, contextId])
}

/// Prior version snapshots for replace/rollback (URLs + metadata — not file bytes).
model AssetVersion {
  id                String   @id @default(cuid())
  wordpressMediaId  Int
  version           Int
  previousMediaId   Int?
  previousSourceUrl String
  title             String?
  alt               String?
  mimeType          String?
  width             Int?
  height            Int?
  metadata          Json?
  createdById       String?
  createdAt         DateTime @default(now())

  @@unique([wordpressMediaId, version])
  @@index([wordpressMediaId, createdAt])
}

/// Background sync cursor for WordPress → Studio metadata refresh.
model AssetSyncState {
  id                 String    @id @default(cuid())
  key                String    @unique @default("default")
  lastSyncedAt       DateTime?
  lastCursor         String?
  lastMediaModified  DateTime?
  status             String    @default("idle")
  lastError          String?
  updatedAt          DateTime  @updatedAt
}

// =============================================================================
// Lead Engine (ADR-013) — patient enquiries / mini CRM / append-only timeline.
// Isolated from Experience Studio presentation models. Never store WP HTML.
// =============================================================================

enum LeadStatus {
  NEW
  CONTACT_ATTEMPTED
  CONTACTED
  INTERESTED
  QUALIFIED
  APPOINTMENT_SCHEDULED
  APPOINTMENT_COMPLETED
  TREATMENT_STARTED
  CONVERTED
  LOST
  SPAM
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PreferredContactMethod {
  PHONE
  WHATSAPP
  EMAIL
}

enum PreferredTime {
  MORNING
  AFTERNOON
  EVENING
}

enum LeadTimelineEventType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_ASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  INTERNAL_NOTE_ADDED
  DOCTOR_ASSIGNED
  STAFF_ASSIGNED
  EMAIL_SENT
  WHATSAPP_SENT
  SMS_SENT
  APPOINTMENT_SCHEDULED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_COMPLETED
  LEAD_CONVERTED
  LEAD_LOST
  SPAM_MARKED
  LEAD_REOPENED
  DUPLICATE_DETECTED
  FORM_ANALYTICS
}

/// Patient consultation enquiry captured from the public website.
model Lead {
  id                     String                 @id @default(cuid())
  uuid                   String                 @unique @default(uuid())
  name                   String
  phone                  String
  email                  String?
  message                String?
  treatment              String?
  preferredContactMethod PreferredContactMethod @default(PHONE)
  preferredTime          PreferredTime?

  /// Originating page attribution (denormalized — never live WP fetches).
  pageTitle              String?
  pageSlug               String?
  pageUri                String?
  pageId                 String?
  presentationPageId     String?
  presentationVersion    String?
  template               String?
  theme                  String?
  currentUrl             String?
  referrer               String?

  utmSource              String?
  utmMedium              String?
  utmCampaign            String?
  utmContent             String?
  utmTerm                String?

  device                 String?
  browser                String?
  os                     String?
  screenSize             String?
  language               String?
  country                String?
  ip                     String?
  sessionId              String?
  visitorId              String?
  timezone               String?

  leadScore              Int                    @default(0)
  status                 LeadStatus             @default(NEW)
  priority               LeadPriority           @default(MEDIUM)
  assignedDoctor         String?
  assignedStaff          String?

  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  lastActivityAt         DateTime               @default(now())
  deletedAt              DateTime?

  timeline               LeadTimelineEvent[]
  notes                  LeadNote[]

  @@index([status, priority])
  @@index([phone])
  @@index([email])
  @@index([pageSlug])
  @@index([createdAt])
  @@index([lastActivityAt])
  @@index([visitorId])
  @@index([sessionId])
  @@index([deletedAt])
}

/// Append-only activity history — never edit or delete for audit rewriting.
model LeadTimelineEvent {
  id                String                @id @default(cuid())
  leadId            String
  lead              Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  eventType         LeadTimelineEventType
  title             String
  description       String?
  metadata          Json?
  performedByUserId String?
  systemGenerated   Boolean               @default(true)
  createdAt         DateTime              @default(now())

  @@index([leadId, createdAt])
  @@index([eventType])
  @@index([createdAt])
}

/// Internal CRM notes (each create also appends a timeline event).
model LeadNote {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  body            String
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([leadId, createdAt])
}
